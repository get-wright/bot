{
  "name": "sast-triage",
  "version": "0.2.0",
  "description": "Agentic SAST finding triage via LLM-driven codebase exploration",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts src/core/worker/entry.ts --compile --define 'process.env.NODE_ENV=\"production\"' --outfile sast-triage",
    "dev": "bun run src/index.ts",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:integration": "bun --bun ./node_modules/.bin/vitest run tests/integration/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.78",
    "@ai-sdk/google": "^2.0.71",
    "@ai-sdk/openai": "^2.0.104",
    "@modelcontextprotocol/sdk": "^1",
    "ai": "^5.0.180",
    "better-sqlite3": "^12",
    "commander": "^14",
    "langsmith": "^0.5.26",
    "smol-toml": "^1.6.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "typescript": "^5.9",
    "vitest": "^3.0.0"
  }
}
